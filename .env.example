# ════════════════════════════════════════════════════════
#  Hengs Discord Bot (Henzzz) — contoh konfigurasi
#  Copy file ini jadi `.env`, lalu isi value-nya.
#  JANGAN PERNAH commit file .env asli ke Git!
# ════════════════════════════════════════════════════════

# ── Bot credentials (Discord Developer Portal) ──
# Bot -> Reset Token. JANGAN share; regenerate kalau bocor.
DISCORD_TOKEN=
# General Information -> Application ID
DISCORD_CLIENT_ID=
# Aktifkan Developer Mode -> klik-kanan server -> Copy Server ID
DISCORD_GUILD_ID=

# ── Channel IDs (klik-kanan channel -> Copy Channel ID) ──
ANNOUNCE_CHANNEL_ID=
WELCOME_CHANNEL_ID=
GSA_CHANNEL_ID=
BOT_CHANNEL_ID=
RULES_CHANNEL_ID=
ROLES_CHANNEL_ID=
LEAVE_CHANNEL_ID=

# ── Role auto-assign pas member join (kosongin kalau belum ada) ──
MEMBER_ROLE_ID=

# ── AI (buat chat via mention) ──
# Groq: https://console.groq.com  |  OpenRouter: https://openrouter.ai
GROQ_API_KEY=
OPENROUTER_API_KEY=
